# Database
POSTGRES_USER=vehitrack_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://vehitrack_user:password@postgres/vehitrack

# Security
SECRET_KEY=replace_this_with_a_secure_random_string
REDIS_PASSWORD=change_me_in_production

# MinIO
MINIO_ACCESS_KEY=vehitrack_minio
MINIO_SECRET_KEY=change_me_in_production

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Email (Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@vehitrack.io
SMTP_PASSWORD=app_specific_password

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,https://vehitrack.yourdomain.com
